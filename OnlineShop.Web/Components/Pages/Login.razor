@page "/login"
@inject OnlineShop.Web.Services.AuthService AuthService
@inject OnlineShop.Web.Services.CustomAuthStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <h3>Вход</h3>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="mb-3">
                <label>Email</label>
                <input class="form-control" @bind="email" type="email" />
            </div>
            <div class="mb-3">
                <label>Пароль</label>
                <input class="form-control" @bind="password" type="password" />
            </div>
            <button class="btn btn-primary w-100" @onclick="HandleLogin">Войти</button>
            <div class="mt-3 text-center">
                <a href="/register">Нет аккаунта? Зарегистрироваться</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;

        var result = await AuthService.Login(new OnlineShop.Shared.DTOs.LoginDto
        {
            Email = email,
            Password = password
        });

        if (result == null)
        {
            errorMessage = "Неверный email или пароль";
            return;
        }

        await AuthService.SaveToken(result.Token);
        await AuthStateProvider.NotifyAuthStateChanged();
        Navigation.NavigateTo("/");
    }
}