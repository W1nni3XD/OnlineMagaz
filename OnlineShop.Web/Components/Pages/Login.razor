@page "/login"
@inject OnlineShop.Web.Services.AuthService AuthService
@inject OnlineShop.Web.Services.CustomAuthStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using OnlineShop.Web.Services
@using MudBlazor
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-6">
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">Вход</MudText>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
        }

        <MudTextField @bind-Value="email"
                      Label="Email"
                      Variant="Variant.Outlined"
                      InputType="InputType.Email"
                      Class="mb-3" />

        <MudTextField @bind-Value="password"
                      Label="Пароль"
                      Variant="Variant.Outlined"
                      InputType="InputType.Password"
                      Class="mb-4" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="HandleLogin">
            Войти
        </MudButton>

        <MudText Align="Align.Center" Class="mt-3">
            Нет аккаунта? <MudLink Href="/register">Зарегистрироваться</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;

        var result = await AuthService.Login(new OnlineShop.Domain.DTOs.LoginDto
        {
            Email = email,
            Password = password
        });

        if (result == null)
        {
            errorMessage = "Неверный email или пароль";
            return;
        }

        await AuthService.SaveToken(result.Token);
        await ((CustomAuthStateProvider)AuthStateProvider).NotifyAuthStateChanged();
        Navigation.NavigateTo("/");
    }
}