@page "/register"
@inject OnlineShop.Web.Services.AuthService AuthService
@inject OnlineShop.Web.Services.CustomAuthStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using OnlineShop.Web.Services
@using MudBlazor
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-6">
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">Регистрация</MudText>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
        }

        <MudTextField @bind-Value="email"
                      Label="Email"
                      Variant="Variant.Outlined"
                      InputType="InputType.Email"
                      Class="mb-3" />

        <MudTextField @bind-Value="password"
                      Label="Пароль"
                      Variant="Variant.Outlined"
                      InputType="InputType.Password"
                      Class="mb-3" />

        <MudText Class="mb-2">Роль</MudText>
        <MudRadioGroup @bind-Value="role" Class="mb-4">
            <MudRadio Value="@("Buyer")" Color="Color.Primary">Покупатель</MudRadio>
            <MudRadio Value="@("Seller")" Color="Color.Primary">Продавец</MudRadio>
        </MudRadioGroup>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="HandleRegister">
            Зарегистрироваться
        </MudButton>

        <MudText Align="Align.Center" Class="mt-3">
            Уже есть аккаунт? <MudLink Href="/login">Войти</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string role = "Buyer";
    private string errorMessage = string.Empty;

    private async Task HandleRegister()
    {
        errorMessage = string.Empty;

        var result = await AuthService.Register(new OnlineShop.Shared.DTOs.RegisterDto
        {
            Email = email,
            Password = password,
            Role = role
        });

        if (result == null)
        {
            errorMessage = "Ошибка регистрации. Попробуйте другой email";
            return;
        }

        await AuthService.SaveToken(result.Token);
        await ((CustomAuthStateProvider)AuthStateProvider).NotifyAuthStateChanged();
        Navigation.NavigateTo("/");
    }
}