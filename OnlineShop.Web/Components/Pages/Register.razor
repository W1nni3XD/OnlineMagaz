@page "/register"
@using Microsoft.AspNetCore.Components.Authorization
@using OnlineShop.Web.Services
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <h3>Регистрация</h3>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="mb-3">
                <label>Email</label>
                <input class="form-control" @bind="email" type="email" />
            </div>
            <div class="mb-3">
                <label>Пароль</label>
                <input class="form-control" @bind="password" type="password" />
            </div>
            <div class="mb-3">
                <label>Роль</label>
                <select class="form-control" @bind="role">
                    <option value="Buyer">Покупатель</option>
                    <option value="Seller">Продавец</option>
                </select>
            </div>
            <button class="btn btn-primary w-100" @onclick="HandleRegister">
                Зарегистрироваться
            </button>
            <div class="mt-3 text-center">
                <a href="/login">Уже есть аккаунт? Войти</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string role = "Buyer";
    private string errorMessage = string.Empty;

    private async Task HandleRegister()
    {
        errorMessage = string.Empty;

        var result = await AuthService.Register(new OnlineShop.Shared.DTOs.RegisterDto
        {
            Email = email,
            Password = password,
            Role = role
        });

        if (result == null)
        {
            errorMessage = "Ошибка регистрации. Попробуйте другой email";
            return;
        }

        await AuthService.SaveToken(result.Token);
        await ((CustomAuthStateProvider)AuthStateProvider).NotifyAuthStateChanged();
        Navigation.NavigateTo("/");
    }
}