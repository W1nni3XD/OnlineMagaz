@page "/catalog"
@using MudBlazor
@using OnlineShop.Web.Services
@using OnlineShop.Shared.DTOs
@inject ProductService ProductService
@inject CategoryService CategoryService
@inject CartService CartService
@inject NavigationManager Navigation
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="4">
            <MudTextField @bind-Value="searchQuery"
                          Label="Поиск товаров"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          @onkeyup="HandleSearch" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudSelect @bind-Value="selectedCategory"
                       Label="Категория"
                       Variant="Variant.Outlined"
                       @bind-Value:after="LoadProducts">
                <MudSelectItem Value="0">Все категории</MudSelectItem>
                @foreach (var cat in categories)
                {
                    <MudSelectItem Value="@cat.Id">@cat.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>

    @if (isLoading)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else if (!products.Any())
    {
        <MudAlert Severity="Severity.Info">Товары не найдены</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var product in products)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="2" Style="border-radius: 12px; height: 100%;">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <MudCardMedia Image="@product.ImageUrl" Height="200" />
                        }
                        else
                        {
                            <div style="height: 200px; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">
                                <MudIcon Icon="@Icons.Material.Filled.Image" Style="font-size: 4rem; color: #ccc;" />
                            </div>
                        }
                        <MudCardContent>
                            <MudText Typo="Typo.h6" Style="font-weight: 600;">@product.Name</MudText>
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Class="mt-1">@product.CategoryName</MudChip>
                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="mt-2">
                                @product.Price.ToString("C")
                            </MudText>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       OnClick='() => Navigation.NavigateTo($"/product/{product.Id}")'>
                                Подробнее
                            </MudButton>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.ShoppingCart"
                                       OnClick="() => AddToCart(product.Id)">
                                В корзину
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery]
    public int? CategoryId { get; set; }

    private List<ProductDto> products = new();
    private List<CategoryDto> categories = new();
    private string searchQuery = string.Empty;
    private int selectedCategory = 0;
    private bool isLoading = true;
    private bool initialized = false;
    private bool disposed = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !initialized)
        {
            initialized = true;
            try
            {
                categories = await CategoryService.GetAll();
                if (CategoryId.HasValue)
                    selectedCategory = CategoryId.Value;
                await LoadProducts();
            }
            catch { }
            
            if (!disposed)
                await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadProducts()
    {
        if (disposed) return;
        isLoading = true;
        products = await ProductService.GetAll(
            selectedCategory == 0 ? null : selectedCategory,
            string.IsNullOrEmpty(searchQuery) ? null : searchQuery
        );
        isLoading = false;
    }

    private async Task HandleSearch()
    {
        if (disposed) return;
        await LoadProducts();
        if (!disposed)
            await InvokeAsync(StateHasChanged);
    }

    private async Task AddToCart(int productId)
    {
        if (disposed) return;
        await CartService.AddToCart(new OnlineShop.Shared.DTOs.AddToCartDto
        {
            ProductId = productId,
            Quantity = 1
        });
        if (!disposed)
            await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        disposed = true;
    }
}