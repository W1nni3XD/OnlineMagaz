@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
        Главная
    </MudNavLink>
    <MudNavLink Href="catalog" Icon="@Icons.Material.Filled.Store">
        Каталог
    </MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="cart" Icon="@Icons.Material.Filled.ShoppingCart">
                Корзина
            </MudNavLink>
            <MudNavLink Href="orders" Icon="@Icons.Material.Filled.ListAlt">
                Мои заказы
            </MudNavLink>
            <AuthorizeView Roles="Seller" Context="sellerAuth">
                <MudNavLink Href="seller" Icon="@Icons.Material.Filled.Inventory">
                    Мои товары
                </MudNavLink>
            </AuthorizeView>
            <AuthorizeView Roles="Admin" Context="adminAuth">
                <MudNavLink Href="admin" Icon="@Icons.Material.Filled.AdminPanelSettings">
                    Админ панель
                </MudNavLink>
            </AuthorizeView>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>