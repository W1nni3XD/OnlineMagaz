@inherits LayoutComponentBase
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using OnlineShop.Web.Services
@inject CartSidebarState CartSidebarState
@implements IDisposable

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">OnlineShop</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-2" Style="align-self:center;">
                    @(GetProfileLabel(context.User))
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart"
                               Color="Color.Inherit"
                               OnClick="OpenCart" />
                <MudButton Href="/logout" Color="Color.Inherit">Выйти</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Color="Color.Inherit">Войти</MudButton>
                <MudButton Href="/register" Color="Color.Inherit">Регистрация</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="drawerOpen" Elevation="1">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Меню</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>

    <CartSidebar @bind-IsOpen="CartOpen" />
</MudLayout>

<MudThemeProvider />
<MudPopoverProvider />
<MudSnackbarProvider />
<MudDialogProvider />

@code {
    private bool drawerOpen = true;
    private bool cartOpen = false;
    private bool CartOpen
    {
        get => cartOpen;
        set
        {
            if (cartOpen == value) return;
            cartOpen = value;
            CartSidebarState.Set(value);
        }
    }

    protected override void OnInitialized()
    {
        cartOpen = CartSidebarState.IsOpen;
        CartSidebarState.OnChange += HandleCartSidebarStateChanged;
    }

    private void ToggleDrawer()
    {
        drawerOpen = !drawerOpen;
    }

    private void OpenCart()
    {
        CartSidebarState.Open();
    }

    private void HandleCartSidebarStateChanged()
    {
        cartOpen = CartSidebarState.IsOpen;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CartSidebarState.OnChange -= HandleCartSidebarStateChanged;
    }

    private static string GetProfileLabel(ClaimsPrincipal user)
    {
        return user.FindFirst("profile_display")?.Value
               ?? user.FindFirst(ClaimTypes.Email)?.Value
               ?? string.Empty;
    }
}